# 全市场筛选调度默认关闭；手动 API 仍可运行。启用后作为盘后 Agent 前置步骤运行，纽约时间 17:30 兜底。
MARKET_SCREEN_ENABLED=false
MARKET_SCREEN_REFRESH_BARS_ENABLED=true
MARKET_SCREEN_FUNNEL_LIMIT=50
MARKET_SCREEN_MIN_BARS=60
MARKET_SCREEN_MAX_FRESHNESS_DAYS=7
MARKET_SCREEN_REFRESH_CONCURRENCY=10
MARKET_SCREEN_TIMEOUT_MS=840000
MARKET_SCREEN_NEW_YORK_TIME=17:30
# 默认只生成候选 revision；人工确认后再提升。设为 true 才允许运行时改写受 Git 管理的 Skill 文件。
ALL_STOCK_AGENT_SKILL_AUTO_WRITE_ENABLED=false
IBKR_FLEX_TOKEN=
IBKR_FLEX_QUERY_ID=
IBKR_FLEX_VERSION=3
IBKR_FLEX_USER_AGENT="MarketPulseAI/0.1"
